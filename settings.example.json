{
  "effortLevel": "medium",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/usage-guard.sh refresh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/post-compact.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/usage-guard.sh inform"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-router.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent|Workflow",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/usage-guard.sh block"
          }
        ]
      }
    ]
  }
}
